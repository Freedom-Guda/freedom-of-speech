{
  "name": "@fos/sdk",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Drop-in embed SDK for native site integration — zero runtime dependencies",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./auto": {
      "import": "./dist/auto.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint not yet configured'"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.5",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
