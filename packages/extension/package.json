{
  "name": "@fos/extension",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Freedom of Speech browser extension",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not yet configured'",
    "test": "echo 'tests not yet configured'",
    "wxt:prepare": "wxt prepare"
  },
  "dependencies": {
    "@fos/identity": "workspace:*",
    "@fos/protocol": "workspace:*",
    "@fos/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.40",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@wxt-dev/module-react": "^1.1.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wxt": "^0.20.0"
  }
